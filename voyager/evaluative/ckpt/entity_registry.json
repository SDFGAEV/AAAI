    "attack_damage",
    "move_speed",
    "can_explode",
    "drop_value",
    "health",
    "armor",
    "tool_level",
    "minable",
    "hostile",
    "swimming",
    "flying",
    "liquid",
    "solid",
    "flammable",
    "gravity",
    "light_level",
    "reach",
    "tame",
    "breeding",
    "transparency"
  ],
  "features_description": {
    "attack_damage": "Physical damage dealt when attacking (0-10 scale)",
    "move_speed": "Movement speed relative to player (0.0-2.0)",
    "can_explode": "Whether entity can explode (0 or 1)",
    "drop_value": "Value of dropped items (0-10 scale)",
    "health": "Entity health points (0-40 scale)",
    "armor": "Armor points (0-20 scale)",
    "tool_level": "Required tool tier to mine (0=hand, 1=wood, 2=stone, 3=iron, 4=diamond)",
    "minable": "Whether block can be mined (0 or 1)",
    "hostile": "Whether entity attacks players (0 or 1)",
    "swimming": "Whether entity can swim (0 or 1)",
    "flying": "Whether entity can fly (0 or 1)",
    "liquid": "Whether block is liquid (0 or 1)",
    "solid": "Whether block is solid (0 or 1)",
    "flammable": "Whether block is flammable (0 or 1)",
    "gravity": "Whether block has gravity (0 or 1)",
    "light_level": "Light emission level (0-15)",
    "reach": "Attack reach distance (0-5 scale)",
    "tame": "Whether entity can be tamed (0 or 1)",
    "breeding": "Whether entity can be bred (0 or 1)",
    "transparency": "Block transparency (0=opaque, 1=transparent)"
  },
